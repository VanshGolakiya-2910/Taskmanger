# Frontend Environment Configuration

# ========================================
# LOCALHOST DEVELOPMENT (Default)
# Use this for development on your local machine
# ========================================
# VITE_API_BASE_URL=http://localhost:5000/api/v1
# VITE_SOCKET_URL=http://localhost:5000


# ========================================
# KALI VM DEVELOPMENT
# Use this when running frontend in Kali VM
# accessing backend on Ubuntu host
# ========================================
# VITE_API_BASE_URL=http://10.0.2.2:5000/api/v1
# VITE_SOCKET_URL=http://10.0.2.2:5000


# ========================================
# NETWORK ACCESS
# Use this to access from another machine
# on the same network (e.g., 172.16.17.42)
# ========================================
# VITE_API_BASE_URL=http://<YOUR_MACHINE_IP>:5000/api/v1
# VITE_SOCKET_URL=http://<YOUR_MACHINE_IP>:5000
