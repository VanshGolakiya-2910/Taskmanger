NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Database
# Optional for single-container mode (MariaDB socket)
# DB_SOCKET=/app/run/mysqld.sock
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=taskmanager
DB_USER=taskmanager
DB_PASSWORD=replace_with_strong_db_password

# Redis
REDIS_URL=redis://127.0.0.1:6379

# JWT secrets (use strong 32+ char values)
JWT_ACCESS_SECRET=replace_with_strong_access_secret_min_32_chars
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret_min_32_chars

# CORS
ALLOWED_ORIGINS=https://projectname.vishwkarma.net

# Auth rate limiting
AUTH_RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_DISABLE=false

# Uploads
UPLOAD_DIR=uploads
